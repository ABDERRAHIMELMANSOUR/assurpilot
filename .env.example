# ─────────────────────────────────────────────
# DATABASE (PostgreSQL — Neon, Supabase, or Railway)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/assurpilot?sslmode=require"

# ─────────────────────────────────────────────
# NEXTAUTH
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# ─────────────────────────────────────────────
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-app.vercel.app"

# ─────────────────────────────────────────────
# VERCEL CRON (secure the /api/cron/* endpoints)
# Generate with: openssl rand -base64 32
# ─────────────────────────────────────────────
CRON_SECRET="your-cron-secret-here"

# ─────────────────────────────────────────────
# KEYYO (optional — only needed for real webhook auth)
# ─────────────────────────────────────────────
# KEYYO_WEBHOOK_SECRET="your-keyyo-hmac-secret"
